	quest.4099378B803D8CAF.title: "Obtain a &bCoast Armour Trim&r"
	quest.42959B6F1D614D70.quest_desc: ["You can place &6small cogwheels&r next to eachother to keep roational force sideways but the rotations will change from cogwheel to cogwheel"]
	quest.42959B6F1D614D70.quest_subtitle: "The smaller of the cogwheels"
	quest.432111807A61E6C6.quest_subtitle: "Keep track of what you want to do"
	quest.43496DF129AA9132.quest_subtitle: "The start of upgrading your storage capabilities"
	quest.43D4387F9D3CCF41.quest_subtitle: "Full enchanting with liquid XP"
	quest.442159787F607B8E.quest_desc: [
		"The &6crushing wheel&r is used to start processing raw resources more automatically"
		""
		"Some natural spawning blocks from create can be crushed to get resources the list is:"
		""
		"&cCrimsite&r is crushed to get a 40% chance at raw crushed Iron and a nugget"
		"&bAsurine&r is crushed to get a 30% chance at raw crushed Zinc and a nugget"
		"&aVeridium&r is crushed to get a 80% chance at raw crushed Copper and a nugget"
		"&eOchrum&r is crushed to get a 20% chance at raw crushed Gold and a nugget"
	]
	quest.442159787F607B8E.quest_subtitle: "Crushing stuff"
	quest.443868FD42BD73C8.quest_desc: ["The &6mechanical speed controller&r is a easier way to speed up rotational speeds, you can right click it and set the speed you want it to spin at"]
	quest.443868FD42BD73C8.quest_subtitle: "Replaces the cog wheel method"
	quest.457F1F059FD8B0CE.quest_desc: [
		"The &6train door&r has 3 modes and each of the modes decide how the door will intereact."
		""
		"The normal mode lets the player interact with the door but it also will auto open and shut depending on whether the machine is moving or not"
		""
		"The manual mode lets the player interact with the door like it's a regular door"
		""
		"The special mode doesn't let the player interact and will only open and close when moving or with a redstone signal (shift + right click will override the special mode)"
	]
	quest.457F1F059FD8B0CE.quest_subtitle: "Fancy door"
	quest.47A34C2267D6EB1E.quest_desc: ["The &6harvester&r will automatically harvest crops when added to a machine"]
	quest.47A34C2267D6EB1E.quest_subtitle: "Crop harvesting"
	quest.48573F9B8B326804.title: "Summon and kill &dThe Wither&r"
