	quest.79FCBEBFE6E29E44.quest_desc: ["The &6mechinal drill&r is a item that will mine any block infront of it which is really nice for setting up farms that require blocks to be broken, like a cobblestone farm"]
	quest.79FCBEBFE6E29E44.quest_subtitle: "Mines for you"
	quest.7A39A5B9E3CAC840.quest_desc: ["To get the liquid xp from the &6bottle o' enchanting&r you need the item drain, it will give you back the bottle after it has drained the xp"]
	quest.7A39A5B9E3CAC840.quest_subtitle: "Stealing the precious liquid xp"
	quest.7DC9A48B25E63807.quest_desc: ["The &6brass funnel&r is an upgraded andesite funnel, lets you add item filters and moves upto a stack at a time"]
