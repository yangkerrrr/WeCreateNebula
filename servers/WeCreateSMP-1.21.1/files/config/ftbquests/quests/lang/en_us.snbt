	quest.3BF442790F0F281C.quest_desc: [
		"The &6train signal&r helps with keeping trains from going the wrong way as a train won't pass over a &6train signal&r if it is facing the wrong direction."
		"The &6signal&r can be made a 2 way &6signal&r by having one on either side of the track, having a 2 way &6signal&r will make it so a train can pass it if the scheduled station is on the other side"
	]
	quest.3BF442790F0F281C.quest_subtitle: "Help's with train flow"
	quest.3E10D349E202CC89.quest_subtitle: "Aesthetic trapdoor"
