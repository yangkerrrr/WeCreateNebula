	file.0000000000000001.title: "We Create"
	quest.0081604AF08D98A2.quest_desc: [
		"The &6large water wheel&r works the same as the regular water wheel but has a few differences, it will spin slower than a &eregular water wheel&r but it can will produce a higher stress capacity before it stops from over stressing. It also doesn't matter if 1 or more sides are covered as it will produce the same amount of stress units"
		""
		"It can also be aesthetically changed to match any plank type you right click on it"
	]
	quest.0081604AF08D98A2.quest_subtitle: "Bigger but slower"
	quest.0125799CA778E1F4.quest_desc: ["A &6gearbox&r is used to change the direction of rotation"]
	quest.0125799CA778E1F4.quest_subtitle: "You can craft each gearbox into the other one"
	quest.0228747D6C21928F.quest_subtitle: "Make a hoe"
	quest.0228747D6C21928F.title: "Farming away"
	quest.029007D8E8446038.quest_desc: ["The &6train track&r is the thing that the train need to be assembled on and that they run on. They are integral for a train system to work"]
	quest.029007D8E8446038.quest_subtitle: "The key to train travel"
	quest.02FDDF872A9667BA.quest_desc: ["The &6chute&r acts similar to a hopper and dropper combined, as you can stack them on top of eachother and they will continue to funnnel the items down and drop them once they reach the end but they can also push items up if there is an &6encased fan&r blowing air up through the &6chute&r"]
	quest.02FDDF872A9667BA.quest_subtitle: "A way to move items"
	quest.02FE61BB85143811.quest_desc: [
		"The &6weighted ejector&r let's you send items through the air. "
		"To select the place that the &6ejector&r will send to, you shift right click the block you want it to land on then you can place the &6ejector&r down where you want the items to be flung from."
		""
		"You can edit the weight of the &6ejector&r, to do that you find an x on the &6ejector&r then hold right click whilst looking at it and then move the scroll wheel that appears to the amount of items that you want to be on the &6ejector&r"
	]
	quest.02FE61BB85143811.quest_subtitle: "Fling Items through the air"
	quest.035D8D1D349F7BC3.title: "Enter an &6Ancient City&r"
	quest.03C063D04037EEA7.quest_desc: ["Create has a feature built into it called &6Ponder&r, you can hold W on any create item and when the bar fills you will get shown how you can use the item in the world"]
	quest.03C063D04037EEA7.quest_subtitle: "Click the tick to start learning"
	quest.03E500405A6CA1FB.quest_desc: ["The &6half drawers&r hold half of their respective full sized drawers"]
	quest.03E500405A6CA1FB.quest_subtitle: "What it holds"
	quest.0420DD4A8BB3868F.quest_desc: ["The &6mechanical arm&r can be setup to move items from one spot to another spot like depot to depot"]
	quest.0420DD4A8BB3868F.quest_subtitle: "A helping hand"
	quest.049BDED68524411F.quest_desc: [
		"The &6train observer&r will look at a specific part of the train track and detect when a train is crossing that specific section of track. It will give out a redstone signal when it detects a train going over that piece of track"
		""
		"The &6train observer&r can also only detect when a specific cargo is being held within the train."
	]
	quest.049BDED68524411F.quest_subtitle: "Watches for trains"
	quest.04D70707F44E6366.title: "Locate a &6Deep Dark&r"
	quest.05821667594CB9D1.quest_desc: ["&6Andesite casing&r is one of the most used items in the start of create it is used to make a bunch of helpful blocks to make progress"]
	quest.05821667594CB9D1.quest_subtitle: "Right click a stripped log with an &6andesite alloy&r"
	quest.05D344B86D2AD2AA.title: "Build a &dNether Portal&r"
	quest.05DE72DD68A60883.title: "Obtain any log"
	quest.06CD5DEE6AA5CAD2.quest_desc: ["The &61x1 drawer&r holds a total of &632 stacks&r of the dedicated item"]
	quest.06CD5DEE6AA5CAD2.quest_subtitle: "What it holds"
