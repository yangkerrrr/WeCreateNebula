	quest.118D443869E39F1A.quest_desc: ["The &6portable storage interface&r needs 2 to work correctly, one of them on the machine and the other one not attached to the machine and with a 1 block gap and aligned with eachother before the machine is started so that on each rotation is will deposit the excess items into the stationary one"]
	quest.118D443869E39F1A.quest_subtitle: "Move items from farms to storage"
	quest.11CBF2CE777F8CDF.quest_desc: [
		"&6Blaze burners&r as used to heat up the basin which is needed to make certain things like &6brass&r"
		""
		"To collect blazes in a &6blaze burner&r you can either right click a blaze with an empty &6blaze burner&r or right click a blaze spawner to collect them"
	]
	quest.11CBF2CE777F8CDF.quest_subtitle: "Used to heat a basin below a mixer"
	quest.11CBF2CE777F8CDF.title: "Blaze Burner"
	quest.12BE4EBECF60E611.quest_subtitle: "8x base storage capacity"
