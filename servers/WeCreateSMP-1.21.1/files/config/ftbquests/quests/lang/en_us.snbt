	quest.6D8322083F35B581.quest_desc: ["The &6pipe&r and &6mechanical pump&r are used hand in hand to move liquids around, the &6pump&r does need to be given so rotational speed, depending on the way the rotation goes decideds which way by default the &6pump&r wants to move the liquid, the wrench can be used on it to switch the way the liquid is moved by the pump"]
	quest.6D8322083F35B581.quest_subtitle: "Moving liquid in pipes"
	quest.6E1DCAFE1A9CE229.quest_desc: ["&6Shafts&r are way to transfer a rotation in a straight line either vertical or horizontal"]
	quest.6E1DCAFE1A9CE229.quest_subtitle: "Crafted with 2 andesite alloy"
	quest.6E1DCAFE1A9CE229.title: "Make a shaft"
	quest.6FDAC276AFE8C11C.quest_desc: [
		"To speed up cogwheels you can place a &dlarge cogwheel&r adjacent to a &6small cogwheel&r"
		""
		"Then place a &dlarge cogwheel&r on the face of a &6small cogwheel&r"
		""
		"Then repeat the process as much as you can with the stress units you have available"
	]
	quest.6FDAC276AFE8C11C.quest_subtitle: " "
	quest.6FDD8A97C9F5E461.quest_desc: [
		"The &6drawer controller slave&r is kind of like the &eregular drawer controller&r but it needs a &edrawer controller&r within 12 blocks to work."
		""
