	quest.608A74EE3C04347E.quest_desc: ["The &6spout&r can be used to drop liquid onto an item that's below it on a depot or belt to be able to change what the item is"]
	quest.608A74EE3C04347E.quest_subtitle: "Liquid used in crafting?"
