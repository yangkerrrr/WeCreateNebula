	quest.2ECEAFAF8FDFF38B.title: "Collect Swift Sneak 3"
	quest.34C409E6FF596E2A.quest_desc: [
		"The &6train schedule&r is helpful as you can decide what order a train goes from station to station and how long it is at the station before it departs for the next station."
		""
		"You can right click a mob on a &ered seat&r that is next to the train controls to set that mob as the train conductor and they will follow the train schedule"
	]
	quest.34C409E6FF596E2A.quest_subtitle: "Decide when trains move"
	quest.34CF8CC6400ACAB7.quest_desc: ["When you place a &9windmill bearing&r down you can place a plank on top of it to be able to connect the &bsails&r to"]
